+def _build_support_timeline_event(
+    *,
+    event_type,
+    ticket_id,
+    occurred_at="",
+    actor_name="",
+    message="",
+    before_summary="",
+    after_summary="",
+    snapshot_uid="",
+    event_key="",
+):
+    normalized_ticket_id = int(ticket_id or 0)
+    event_at = str(occurred_at or "").strip()
+    if normalized_ticket_id <= 0 or not event_at:
+        return None
+    return {
+        "id": str(event_key or f"{snapshot_uid}:{event_type}:{normalized_ticket_id}").strip(),
+        "event_type": str(event_type or "").strip(),
+        "request_id": str(normalized_ticket_id),
+        "related_ticket_id": normalized_ticket_id,
+        "actor": str(actor_name or "").strip() or "시스템",
+        "occurred_at": event_at,
+        "before_summary": str(before_summary or "").strip(),
+        "after_summary": str(after_summary or "").strip(),
+        "message": str(message or "").strip(),
+    }
+
