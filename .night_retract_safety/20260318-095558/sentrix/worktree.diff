+def _load_support_timeline_events_by_ticket_ids(conn, ticket_ids):
+    normalized_ids = [
+        int(ticket_id or 0)
+        for ticket_id in list(ticket_ids or [])
+        if int(ticket_id or 0) > 0
+    ]
+    events_by_ticket = {ticket_id: [] for ticket_id in normalized_ids}
+    if not normalized_ids:
+        return events_by_ticket
+
+    placeholders = ",".join(["?"] * len(normalized_ids))
+    snapshot_rows = conn.execute(
+        f"""
+        SELECT id, snapshot_uid, ticket_id, source_kind, payload_json, created_at
+        FROM support_roster_snapshots
+        WHERE ticket_id IN ({placeholders})
+        ORDER BY ticket_id ASC, id ASC
+        """,
+        normalized_ids,
+    ).fetchall()
+    audit_rows = conn.execute(
+        f"""
+        SELECT a.id, a.action, a.target_id, a.details, a.created_at,
+               COALESCE(u.full_name, '') AS actor_name,
+               COALESCE(u.username, '') AS actor_username
+        FROM audit_logs a
+        LEFT JOIN users u ON u.id = a.actor_user_id
+        WHERE a.target_type = 'TICKET'
+          AND a.target_id IN ({placeholders})
+          AND a.action IN ('SAVE_SUPPORT_CONFIRMED_WORKERS', 'CONSUME_SUPPORT_ROSTER_SNAPSHOT')
+        ORDER BY a.id ASC
+        """,
+        [str(ticket_id) for ticket_id in normalized_ids],
+    ).fetchall()
+    audit_by_snapshot_uid = {}
+    for audit_row in audit_rows:
+        details_obj = safe_json_loads(audit_row["details"], {})
+        if not isinstance(details_obj, dict):
+            continue
+        snapshot_uid = str(details_obj.get("snapshot_uid") or "").strip()
+        if snapshot_uid:
+            audit_by_snapshot_uid[snapshot_uid] = {
+                "id": audit_row["id"],
+                "action": str(audit_row["action"] or "").strip(),
+                "created_at": str(audit_row["created_at"] or "").strip(),
+                "actor_name": str(audit_row["actor_name"] or "").strip(),
+                "actor_username": str(audit_row["actor_username"] or "").strip(),
+            }
+
+    for snapshot_row in snapshot_rows:
+        ticket_id = int(snapshot_row["ticket_id"] or 0)
+        if ticket_id <= 0 or ticket_id not in events_by_ticket:
+            continue
+        snapshot_uid = str(snapshot_row["snapshot_uid"] or "").strip()
+        payload_obj = safe_json_loads(snapshot_row["payload_json"], {})
+        if not isinstance(payload_obj, dict):
+            payload_obj = {}
+        audit_entry = audit_by_snapshot_uid.get(snapshot_uid) or {}
+        occurred_at = str(audit_entry.get("created_at") or snapshot_row["created_at"] or "").strip()
+        actor_name = _resolve_support_timeline_actor_name(audit_entry, snapshot_row["source_kind"])
+        previous_workers = normalize_support_confirmed_workers(payload_obj.get("previous_workers") or [])
+        next_workers = normalize_support_confirmed_workers(payload_obj.get("next_workers") or [])
+        previous_worker_map = _build_support_timeline_worker_map(previous_workers)
+        next_worker_map = _build_support_timeline_worker_map(next_workers)
+        all_slots = sorted(set(previous_worker_map.keys()) | set(next_worker_map.keys()))
+        for slot_index in all_slots:
+            previous_row = previous_worker_map.get(slot_index)
+            next_row = next_worker_map.get(slot_index)
+            previous_label = _format_support_timeline_worker_label(previous_row)
+            next_label = _format_support_timeline_worker_label(next_row)
+            event_payload = None
+            if previous_row and next_row:
+                previous_signature = (
+                    str(previous_row.get("employee_id") or "").strip(),
+                    str(previous_row.get("affiliation") or "").strip(),
+                    str(previous_row.get("worker_name") or "").strip(),
+                )
+                next_signature = (
+                    str(next_row.get("employee_id") or "").strip(),
+                    str(next_row.get("affiliation") or "").strip(),
+                    str(next_row.get("worker_name") or "").strip(),
+                )
+                if previous_signature != next_signature:
+                    event_payload = _build_support_timeline_event(
+                        event_type="support_worker_updated",
+                        ticket_id=ticket_id,
+                        occurred_at=occurred_at,
+                        actor_name=actor_name,
+                        message=f"확정 근무자 변경 · {previous_label} -> {next_label}",
+                        before_summary=previous_label,
+                        after_summary=next_label,
+                        snapshot_uid=snapshot_uid,
+                        event_key=f"{snapshot_uid}:support_worker_updated:{slot_index}",
+                    )
+            elif previous_row and not next_row:
+                event_payload = _build_support_timeline_event(
+                    event_type="support_worker_removed",
+                    ticket_id=ticket_id,
+                    occurred_at=occurred_at,
+                    actor_name=actor_name,
+                    message=f"확정 근무자 삭제 · {previous_label}",
+                    before_summary=previous_label,
+                    after_summary="",
+                    snapshot_uid=snapshot_uid,
+                    event_key=f"{snapshot_uid}:support_worker_removed:{slot_index}",
+                )
+            elif next_row and not previous_row:
+                event_payload = _build_support_timeline_event(
+                    event_type="support_worker_added",
+                    ticket_id=ticket_id,
+                    occurred_at=occurred_at,
+                    actor_name=actor_name,
+                    message=f"확정 근무자 추가 · {next_label}",
+                    before_summary="",
+                    after_summary=next_label,
+                    snapshot_uid=snapshot_uid,
+                    event_key=f"{snapshot_uid}:support_worker_added:{slot_index}",
+                )
+            if event_payload:
+                events_by_ticket[ticket_id].append(event_payload)
+
+        previous_status = normalize_support_request_status_key(
+            payload_obj.get("previous_status") or ""
+        )
+        next_status = normalize_support_request_status_key(payload_obj.get("next_status") or "")
+        request_count = max(to_int_safe(payload_obj.get("request_count"), 0), 0)
+        next_count = len(next_workers)
+        if previous_status != next_status:
+            status_event = _build_support_timeline_event(
+                event_type="support_request_status_changed",
+                ticket_id=ticket_id,
+                occurred_at=occurred_at,
+                actor_name=actor_name,
+                message=(
+                    "요청 상태 변경 · "
+                    f"{get_support_request_status_label(previous_status) if previous_status else '미정'}"
+                    f" -> {get_support_request_status_label(next_status) if next_status else '미정'}"
+                ),
+                before_summary=get_support_request_status_label(previous_status) if previous_status else "",
+                after_summary=get_support_request_status_label(next_status) if next_status else "",
+                snapshot_uid=snapshot_uid,
+                event_key=f"{snapshot_uid}:support_request_status_changed",
+            )
+            if status_event:
+                events_by_ticket[ticket_id].append(status_event)
+        if previous_status != "approved" and next_status == "approved":
+            confirmed_event = _build_support_timeline_event(
+                event_type="support_worker_confirmed",
+                ticket_id=ticket_id,
+                occurred_at=occurred_at,
+                actor_name=actor_name,
+                message=f"확정 근무자 등록 완료 · {next_count}/{request_count or next_count}명",
+                before_summary=f"{len(previous_workers)}명",
+                after_summary=f"{next_count}명",
+                snapshot_uid=snapshot_uid,
+                event_key=f"{snapshot_uid}:support_worker_confirmed",
+            )
+            if confirmed_event:
+                events_by_ticket[ticket_id].append(confirmed_event)
+        if request_count > 0 and next_count > request_count:
+            over_assigned_event = _build_support_timeline_event(
+                event_type="support_worker_over_assigned",
+                ticket_id=ticket_id,
+                occurred_at=occurred_at,
+                actor_name=actor_name,
+                message=f"초과 배정 발생 · 요청 {request_count}명 / 등록 {next_count}명",
+                before_summary=f"요청 {request_count}명",
+                after_summary=f"등록 {next_count}명",
+                snapshot_uid=snapshot_uid,
+                event_key=f"{snapshot_uid}:support_worker_over_assigned",
+            )
+            if over_assigned_event:
+                events_by_ticket[ticket_id].append(over_assigned_event)
+
+    for ticket_id in list(events_by_ticket.keys()):
+        events_by_ticket[ticket_id] = sorted(
+            [event for event in events_by_ticket[ticket_id] if isinstance(event, dict) and str(event.get("occurred_at") or "").strip()],
+            key=lambda event: str(event.get("occurred_at") or ""),
+        )
+    return events_by_ticket
+
