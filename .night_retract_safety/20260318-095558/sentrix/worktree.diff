+def _serialize_ticket_api_row(
+    row,
+    *,
+    comments_by_ticket=None,
+    status_history_by_ticket=None,
+    attachments_by_ticket=None,
+    support_timeline_by_ticket=None,
+    hq_upload_ticket_ids=None,
+):
+    row_obj = dict(row or {})
+    template_payload = safe_json_loads(
+        row_obj.get("template_payload_json")
+        or row_obj.get("payload_json")
+        or "{}",
+        {},
+    )
+    if not isinstance(template_payload, dict):
+        template_payload = {}
+    ticket_id = int(row_obj.get("id") or 0)
+    support_request_source = normalize_support_request_origin_value(
+        template_payload.get("support_request_source")
+        or template_payload.get("source")
+        or ""
+    )
+    support_request_origin = normalize_support_request_origin_value(
+        template_payload.get("support_request_origin")
+        or template_payload.get("origin")
+        or support_request_source
+    )
+    confirmed_workers = normalize_support_confirmed_workers_from_payload(template_payload)
+    confirmed_legacy = build_support_confirmed_workers_legacy_fields(confirmed_workers)
+    support_requested_count = get_support_requested_count_from_payload(template_payload)
+    support_request_date = get_support_request_date_from_payload(template_payload, row_obj.get("created_at") or "")
+    support_timeline_events = list((support_timeline_by_ticket or {}).get(ticket_id, []))
+    template_type = normalize_ticket_template_type_name(row_obj.get("template_type") or "")
+    if template_type in SUPPORT_REQUEST_TEMPLATE_TYPES and str(row_obj.get("created_at") or "").strip():
+        created_event = _build_support_timeline_event(
+            event_type="support_request_created",
+            ticket_id=ticket_id,
+            occurred_at=str(row_obj.get("created_at") or "").strip(),
+            actor_name=str(row_obj.get("reporter_name") or row_obj.get("reporter_username") or "").strip() or "시스템",
+            message="지원근무 요청이 등록되었습니다.",
+            before_summary="",
+            after_summary=f"요청 {support_requested_count}명" if support_requested_count > 0 else "",
+            event_key=f"support-created:{ticket_id}:{str(row_obj.get('created_at') or '').strip()}",
+        )
+        if created_event:
+            support_timeline_events = [created_event, *support_timeline_events]
+    return {
+        "id": row_obj.get("id"),
+        "display_no": int(row_obj.get("display_no") or 0),
+        "template_type": row_obj.get("template_type"),
+        "title": row_obj.get("title"),
+        "display_title": make_ticket_title(
+            int(row_obj.get("display_no") or row_obj.get("id") or 0),
+            str(row_obj.get("site_id") or row_obj.get("location") or "").strip(),
+            row_obj.get("template_type"),
+        ),
