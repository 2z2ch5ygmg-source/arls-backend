+def _load_ticket_comments_by_ticket_ids(conn, ticket_ids):
+    normalized_ids = [
+        int(ticket_id or 0)
+        for ticket_id in list(ticket_ids or [])
+        if int(ticket_id or 0) > 0
+    ]
+    comments_by_ticket = {ticket_id: [] for ticket_id in normalized_ids}
+    if not normalized_ids:
+        return comments_by_ticket
+    placeholders = ",".join(["?"] * len(normalized_ids))
+    comment_rows = conn.execute(
+        f"""
+        SELECT c.id, c.ticket_id, c.comment_text, c.created_at,
+               u.id AS user_id, u.full_name, u.username, u.role
+        FROM ticket_comments c
+        JOIN users u ON u.id = c.user_id
+        WHERE c.ticket_id IN ({placeholders})
+        ORDER BY c.id ASC
+        """,
+        normalized_ids,
+    ).fetchall()
+    for row in comment_rows:
+        ticket_id = int(row["ticket_id"] or 0)
+        if ticket_id <= 0 or ticket_id not in comments_by_ticket:
+            continue
+        comments_by_ticket[ticket_id].append(
+            {
+                "id": row["id"],
+                "comment_text": row["comment_text"],
+                "created_at": row["created_at"],
+                "author_user_id": row["user_id"],
+                "author_name": row["full_name"],
+                "author_username": row["username"],
+                "author_role": row["role"],
+            }
+        )
+    return comments_by_ticket
+
+
+def _load_ticket_status_history_by_ticket_ids(conn, ticket_ids):
+    normalized_ids = [
+        int(ticket_id or 0)
+        for ticket_id in list(ticket_ids or [])
+        if int(ticket_id or 0) > 0
+    ]
+    status_history_by_ticket = {ticket_id: [] for ticket_id in normalized_ids}
+    if not normalized_ids:
+        return status_history_by_ticket
+    placeholders = ",".join(["?"] * len(normalized_ids))
+    audit_rows = conn.execute(
+        f"""
+        SELECT
+            a.id,
+            a.target_id,
+            a.details,
+            a.created_at,
+            COALESCE(u.full_name, '') AS actor_name,
+            COALESCE(u.username, '') AS actor_username
+        FROM audit_logs a
+        LEFT JOIN users u ON u.id = a.actor_user_id
+        WHERE a.target_type = 'TICKET'
+          AND a.action = 'UPDATE_TICKET_STATUS'
+          AND a.target_id IN ({placeholders})
+        ORDER BY a.id ASC
+        """,
+        [str(ticket_id) for ticket_id in normalized_ids],
+    ).fetchall()
+    for audit_row in audit_rows:
+        target_ticket_id = to_int_safe(audit_row["target_id"], 0)
+        if target_ticket_id <= 0 or target_ticket_id not in status_history_by_ticket:
+            continue
+        raw_details = str(audit_row["details"] or "").strip()
+        status_text, _, decision_reason = raw_details.partition(":")
+        status_history_by_ticket[target_ticket_id].append(
+            {
+                "id": audit_row["id"],
+                "status": str(status_text or "").strip(),
+                "decision_reason": str(decision_reason or "").strip(),
+                "details": raw_details,
+                "created_at": audit_row["created_at"] or "",
+                "actor_name": str(audit_row["actor_name"] or "").strip(),
+                "actor_username": str(audit_row["actor_username"] or "").strip(),
+            }
+        )
+    return status_history_by_ticket
+
+
+def _normalize_support_timeline_worker_rows(rows):
+    normalized = []
+    for index, raw_row in enumerate(normalize_support_confirmed_workers(rows), start=1):
+        row = raw_row if isinstance(raw_row, dict) else {}
+        slot_index = max(to_int_safe(row.get("slot_index"), index), 1)
+        normalized.append(
+            {
+                "slot_index": slot_index,
+                "affiliation": str(row.get("affiliation") or "").strip(),
+                "worker_name": str(row.get("worker_name") or "").strip(),
+                "employee_id": str(row.get("employee_id") or "").strip(),
+            }
+        )
+    return normalized
+
+
+def _build_support_timeline_worker_map(rows):
+    worker_map = {}
+    for index, row in enumerate(_normalize_support_timeline_worker_rows(rows), start=1):
+        slot_index = max(to_int_safe(row.get("slot_index"), index), 1)
+        while slot_index in worker_map:
+            slot_index += 1
+        worker_map[slot_index] = row
+    return worker_map
+
+
+def _format_support_timeline_worker_label(worker_row):
+    return format_support_worker_push_text(worker_row)
+
