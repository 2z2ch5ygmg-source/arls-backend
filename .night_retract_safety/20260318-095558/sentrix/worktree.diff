+def _resolve_support_timeline_actor_name(audit_entry, snapshot_source_kind=""):
+    audit_obj = audit_entry if isinstance(audit_entry, dict) else {}
+    actor_name = str(audit_obj.get("actor_name") or audit_obj.get("actor_username") or "").strip()
+    if actor_name:
+        return actor_name
+    if str(snapshot_source_kind or "").strip().lower().startswith("arls_"):
+        return "ARLS Bridge"
+    return "HQ"
+
