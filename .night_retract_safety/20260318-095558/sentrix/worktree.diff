+def resolve_apple_weekly_truth_tenant_code(conn, tenant_id="", explicit_tenant_code=""):
+    explicit = normalize_login_tenant_code(explicit_tenant_code)
+    legacy_explicit = explicit == "apple"
+    normalized_tenant_id = normalize_tenant_id(tenant_id or DEFAULT_TENANT_ID)
+    registry_tenant_id = normalize_login_tenant_code(tenant_id or DEFAULT_TENANT_ID) or normalized_tenant_id
+
+    # Legacy APPLE-only overrides are no longer valid in production; prefer the
+    # actual customer tenant code resolved from the registry for the current tenant.
+    if explicit and not legacy_explicit:
+        return explicit
+
+    tenant_columns = table_columns(conn, "tenants")
+    if tenant_columns:
+        tenant_id_columns = [column for column in ("id", "tenant_id") if column in tenant_columns]
+        tenant_code_columns = [column for column in ("tenant_code", "code") if column in tenant_columns]
+        for tenant_id_column in tenant_id_columns:
+            for tenant_code_column in tenant_code_columns:
+                try:
+                    row = conn.execute(
+                        f"""
+                        SELECT {tenant_code_column} AS tenant_code
+                        FROM tenants
+                        WHERE REPLACE(LOWER(TRIM(COALESCE(NULLIF({tenant_id_column}, ''), ''))), '-', '_') = ?
+                        LIMIT 1
+                        """,
+                        (registry_tenant_id,),
+                    ).fetchone()
+                except Exception:
+                    row = None
+                resolved_code = normalize_login_tenant_code(row["tenant_code"] if row else "")
+                if resolved_code:
+                    return resolved_code
+
+    normalized_tenant_code = normalize_login_tenant_code(normalized_tenant_id)
+    if normalized_tenant_code and tenant_registry_code_exists(conn, normalized_tenant_code):
+        return normalized_tenant_code
+
+    if explicit and not legacy_explicit and tenant_registry_code_exists(conn, explicit):
+        return explicit
+    if explicit and not legacy_explicit:
+        return explicit
+    return normalized_tenant_code or normalize_login_tenant_code(DEFAULT_TENANT_ID)
+
